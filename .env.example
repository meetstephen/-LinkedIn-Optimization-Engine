# ══════════════════════════════════════════════════════════════
# LinkedIn Optimization Engine — Environment Variables
# Copy this file to .env and fill in your API keys
# ══════════════════════════════════════════════════════════════

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/min, 1M tokens/day (Gemini 1.5 Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Stability AI API Key (Primary Image Generation)
# Get from: https://platform.stability.ai/account/keys
# Free credits available for new accounts
STABILITY_API_KEY=your_stability_ai_key_here

# Hugging Face API Key (Fallback Image Generation)
# Get from: https://huggingface.co/settings/tokens
# Free tier: many inference API calls
HUGGING_FACE_API_KEY=your_hugging_face_key_here
